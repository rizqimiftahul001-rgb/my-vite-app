  "paths": {
    "/changeBalance": {
      "post": {
        "tags": ["Call Back API"],
        "summary": "Change Balance",
        "description": "End Point : `/changeBalance`",
        "operationId": "changeBalance",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "user": {
                  "type": "string"
                },
                "transaction_type": {
                  "type": "string"
                },
                "reason": {
                  "type": "string"
                },
                "amount": {
                  "type": "number"
                },
                "currency_code": {
                  "type": "string"
                },
                "transaction_id": {
                  "type": "number"
                },
                "transaction_timestamp": {
                  "type": "string",
                  "format": "date-time"
                },
                "round_id": {
                  "type": "string"
                },
                "round_finished": {
                  "type": "boolean"
                },
                "game_id": {
                  "type": "string"
                },
                "user_data": {
                  "type": "object",
                  "properties": {
                    "user_id": {
                      "type": "string"
                    },
                    "amount": {
                      "type": "number"
                    }
                  }
                },
                "game_data": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "provider_game_id": {
                      "type": "string"
                    },
                    "title": {
                      "type": "string"
                    },
                    "platform": {
                      "type": "string"
                    },
                    "type": {
                      "type": "string"
                    },
                    "vendor": {
                      "type": "string"
                    },
                    "game_type": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "type": "object",
                "example": {
                  "code": 1
                }
              }
            }
          },
          "400": {
            "description": "API error (`/changeBalance` API call response must be within 5 second. if responce not comming within 5 second API call will time out with responce `code: 2`)",
            "content": {
              "application/json": {
                "type": "object",
                "example": {
                  "code": 2
                }
              }
            }
          }
        }
      }
    },
    "/balance": {
      "get": {
        "tags": ["Call Back API"],
        "summary": "Balance",
        "description": "End Point: `/balance`",
        "operationId": "balance",
        "parameters": [
          {
            "in": "query",
            "name": "user_id",
            "description": "Casino User ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "type": "object",
                "example": {
                  "code": 1,
                  "money": 1500
                }
              }
            }
          },
          "404": {
            "description": "User not found error",
            "content": {
              "application/json": {
                "type": "object",
                "example": {
                  "code": 0,
                  "money": 0
                }
              }
            }
          },
          "400": {
            "description": "Other error message API error (`/balance` API call response must be within 5 second. if responce not comming within 5 second API call will time out with responce `code: 2`)",
            "content": {
              "application/json": {
                "type": "object",
                "example": {
                  "code": 2,
                  "money": 0
                }
              }
            }
          }
        }
      }
    }
  },
