{
	"openapi": "3.0.2",
	"servers": [
		{
			"url": ""
		}
	],
	"paths": {
		"/api/create-user": {
			"post": {
				"tags": [
					"User Create API"
				],
				"summary": "Create User",
				"description": "create-user",
				"operationId": "create-user",
				"parameters": [
					{
						"name": "user",
						"in": "body",
						"description": "Casino User Name",
						"required": true,
						"schema": {
							"type": "string"
						}
					}
				],
				"responses": {
					"201": {
						"description": "Successful operation",
						"content": {
							"application/json": {
								"type": "object",
								"example": {
									"data": {
										"username": "test_user",
										"balance_amount": 0,
										"currency": "KRW",
										"created_at": "2023-08-07 00:37:06"
									},
									"status": {
										"error": false,
										"message": "Casino user created successfully",
										"timestamp": "2023-08-06T15:37:07.000Z"
									}
								}
							}
						}
					},
					"400": {
						"description": "Header authorization is required",
						"content": {
							"application/json": {
								"type": "object",
								"example": {
									"data": {},
									"status": {
										"error": true,
										"error_message": "Header authorization is required",
										"error_code": "as_01",
										"timestamp": "2023-08-06T15:34:05.480Z"
									}
								}
							}
						}
					}
				}
			}
		},
		"/api/user-money": {
			"get": {
				"tags": [
					"User Money API"
				],
				"summary": "Get User Money",
				"description": "user-money",
				"operationId": "user-money",
				"parameters": [
					{
						"name": "uid",
						"in": "query",
						"description": "Casino User ID",
						"required": true,
						"schema": {
							"type": "string"
						}
					}
				],
				"responses": {
					"200": {
						"description": "Successful operation",
						"content": {
							"application/json": {
								"type": "object",
								"example": {
									"data": {
										"uid": "test01",
										"amount": 15600
									},
									"status": {
										"error": false,
										"message": "User money fetched successfully",
										"timestamp": "2023-08-06T16:10:26.288Z"
									}
								}
							}
						}
					},
					"400": {
						"description": "User money fetched failed",
						"content": {
							"application/json": {
								"type": "object",
								"example": {
									"data": {},
									"status": {
										"error": true,
										"error_message": "User money fetched failed",
										"error_code": "as_09",
										"timestamp": "2023-08-06T16:09:15.863Z"
									}
								}
							}
						}
					}
				}
			}
		}
	}
}